tex/generic/babel-welsh/**

# MetaPost / Metafont
metafont/**
metapost/**
fonts/source/**
mfware/**

# Perl scripts / tools we don't have a runtime for.
scripts/**/*.pl

# Manpages
doc/man/**

# Type1 fonts source (only .pfb is needed at runtime).
fonts/source/**
