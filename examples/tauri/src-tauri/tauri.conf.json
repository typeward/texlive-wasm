{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "texlive-wasm-tauri-example",
  "version": "0.0.0",
  "identifier": "dev.typeward.texlive-wasm.example",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "texlive-wasm — Tauri",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../public/texlive-wasm/*"
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["$RESOURCE/texlive-wasm/**"]
    }
  }
}
