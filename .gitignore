# Build outputs
node_modules/
dist/
build/
.cache/
*.tsbuildinfo

# Engine build artifacts (huge)
engine/build/
engine/source/
engine/.cache/

# Submodule build outputs (but the source trees themselves are tracked).
vendor/*/build/
vendor/*/.libs/

# WASM / data bundles (the staged engine .wasm files under engine-artifacts/ ARE tracked).
*.data
*.tar.br
*.tar.gz
*.tar.zst
# Derived pre-compressed bundles (regenerated by `make optimize`).
*.wasm.br
*.wasm.gz
*.dat.br
*.dat.gz
public/core/
demo/public/core/

# Bundled TDS (56 MB; regenerated by scripts/fetch-tds.sh).
engine-artifacts/texmf/

# Generated PDFs from smoke tests
hello-from-wasm.pdf
hello-from-wasm-xelatex.pdf
hello-from-wasm-lualatex.pdf
hello-from-wasi.pdf
extras-from-wasm.pdf
refs-from-wasm.bbl
sample-from-wasm.ind

# Reference implementations — kept around for study, not part of our project.
example/

# Stray smoke-test files
sm.mjs
smoke.mjs

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local env
.env
.env.local

# Reference projects' own outputs (we never build them from here)
example/*/dist/
example/*/build/
example/*/node_modules/
example/*/public/core/
