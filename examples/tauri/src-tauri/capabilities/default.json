{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window in the texlive-wasm example.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$RESOURCE/texlive-wasm/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$RESOURCE/texlive-wasm/**" }]
    }
  ]
}
