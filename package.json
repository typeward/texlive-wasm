{
  "name": "@typeward/texlive-wasm",
  "version": "0.2.5-alpha",
  "description": "TeX Live in WebAssembly — pdflatex, xelatex, lualatex in the browser and on the edge. Offline-first, Tauri-friendly.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typeward/texlive-wasm.git"
  },
  "homepage": "https://github.com/typeward/texlive-wasm#readme",
  "bugs": {
    "url": "https://github.com/typeward/texlive-wasm/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tauri": {
      "types": "./dist/tauri.d.ts",
      "import": "./dist/tauri.js",
      "require": "./dist/tauri.cjs"
    },
    "./worker": {
      "types": "./dist/core/worker.d.ts",
      "import": "./dist/worker.js",
      "require": "./dist/worker.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "require": "./dist/manifest.cjs"
    }
  },
  "files": [
    "dist/",
    "scripts/cli.cjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "texlive-wasm": "scripts/cli.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepack": "npm run build",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "engines:build": "make -C engine all",
    "engines:clean": "make -C engine clean",
    "manifest:build": "tsx scripts/build-manifest.ts",
    "bundle:build": "tsx scripts/build-bundle.ts",
    "artifacts:validate": "node scripts/validate-artifacts.mjs engine-artifacts",
    "smoke:lazy": "node scripts/smoke-lazy.mjs",
    "tds:pack": "node scripts/pack-tds.mjs",
    "release:pack": "node scripts/pack-release.mjs",
    "tauri": "npm --prefix examples/tauri run tauri --",
    "tauri:dev": "npm --prefix examples/tauri run tauri:dev",
    "tauri:build": "npm --prefix examples/tauri run tauri:build"
  },
  "keywords": [
    "latex",
    "tex",
    "texlive",
    "pdflatex",
    "xelatex",
    "lualatex",
    "bibtexu",
    "webassembly",
    "wasm",
    "wasi",
    "tauri",
    "solidjs",
    "offline",
    "pdf",
    "synctex"
  ],
  "dependencies": {
    "comlink": "^4.4.2"
  },
  "peerDependencies": {
    "@tauri-apps/plugin-fs": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/plugin-fs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
